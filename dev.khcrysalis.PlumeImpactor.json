{
    "app-id": "dev.khcrysalis.PlumeImpactor",
    "runtime": "org.freedesktop.Platform",
    "runtime-version": "25.08",
    "sdk": "org.freedesktop.Sdk",
    "sdk-extensions": [
        "org.freedesktop.Sdk.Extension.rust-stable"
    ],
    "command": "plumeimpactor",
    "finish-args": [
        "--share=network",
        "--socket=fallback-x11",
        "--socket=wayland",
        "--share=ipc",
        "--device=all",
        "--filesystem=/run/usbmuxd",
        "--talk-name=org.kde.StatusNotifierWatcher"
    ],
    "cleanup": [
        "/include",
        "/lib/pkgconfig",
        "/share/pkgconfig",
        "/share/aclocal",
        "/share/doc",
        "/share/man",
        "/share/vala",
        "/share/gtk-doc",
        "/share/libayatana-indicator",
        "/share/libdbusmenu"
    ],
    "modules": [
        "shared-modules/libayatana-appindicator/libayatana-appindicator-gtk3.json",
        {
            "name": "plumeimpactor",
            "buildsystem": "simple",
            "build-commands": [
                "cargo --offline fetch --manifest-path Cargo.toml",
                "cargo --offline build --release --bins --workspace",
                "make install PREFIX=/app PROFILE=release",
                "install -D dev.khcrysalis.PlumeImpactor.metainfo.xml -t /app/share/metainfo"
            ],
            "build-options": {
                "append-path": "/usr/lib/sdk/rust-stable/bin",
                "env": {
                    "CARGO_HOME": "/run/build/plumeimpactor/cargo",
                    "CARGO_NET_OFFLINE": "true"
                }
            },
            "sources": [
                {
                    "type": "file",
                    "url": "https://github.com/CLARATION/Impactor/releases/download/v2.2.3/dev.khcrysalis.PlumeImpactor.metainfo.xml",
                    "sha256": "ea2411a1fe296bcf4f6fb595634d48f7a7875e33e82d4ce6f674fb37d5d67c10",
                    "x-checker-data": {
                        "type": "json",
                        "url": "https://api.github.com/repos/CLARATION/Impactor/releases/latest",
                        "version-query": ".tag_name | sub(\"v\"; \"\")",
                        "url-query": ".assets[] | select(.name == \"dev.khcrysalis.PlumeImpactor.metainfo.xml\") | .browser_download_url"
                    }
                },
                {
                    "type": "git",
                    "url": "https://github.com/claration/Impactor.git",
                    "tag": "v2.2.3",
                    "x-checker-data": {
                        "type": "git",
                        "tag-pattern": "^v([\\d\\.]+)$"
                    },
                    "commit": "6451366629682a9c8a1530f20867bf452bfb4e61"
                },
                "cargo-sources.json"
            ]
        }
    ]
}
